# Local deployment target only. Copy this file to `.env.server`, run
# `chmod 600 .env.server` and never copy it to the VPS.
SHELTER_SERVER_HOST=203.0.113.10
SHELTER_SERVER_PORT=22
SHELTER_SERVER_USER=root
SHELTER_SERVER_PATH=/opt/shelter

# Prefer an SSH key. `$HOME` is expanded because this trusted local file is
# loaded as shell syntax by `ops/deploy.sh` and `ops/deploy-release.sh`.
SHELTER_SERVER_IDENTITY_FILE=$HOME/.ssh/id_ed25519

# Password fallback only. Leave empty when a key or ssh-agent is used. Quote
# values containing shell-special characters, for example: 'correct horse'.
SHELTER_SERVER_PASSWORD=

# Verified release deployments default to asteinberger/shelter. Fork operators
# can pin their own immutable GitHub Release source here or pass --repo.
SHELTER_RELEASE_REPOSITORY=asteinberger/shelter
