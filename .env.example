# Required: initial administrator identity.
ADMIN_EMAIL=admin@example.com
# Initial bootstrap only: install.sh appends this value immediately before the
# first API start and removes it again after the user has been created.
# ADMIN_PASSWORD_B64=base64-encoded-password

# Required: generate with `openssl rand -hex 32`. Never rotate without a migration;
# it encrypts stored Cloudflare credentials, GitHub App credentials, and project
# environment variables.
APP_SECRET=replace-with-64-random-hex-characters

# Local bootstrap access. Keep this bound to loopback and use an SSH tunnel.
PANEL_PORT=7080
PORT=7080
HOST=0.0.0.0

# Runtime paths used by compose. Local development defaults are handled in code.
DATA_DIR=/data
TRAEFIK_CONFIG_PATH=/routing/dynamic.yml
TUNNEL_TOKEN_PATH=/tunnel/tunnel-token
RUNTIME_NETWORK=shelter-runtime
SHELTER_DATA_VOLUME=shelter-data
SHELTER_ROUTING_VOLUME=shelter-routing
SHELTER_TUNNEL_VOLUME=shelter-tunnel
# Host path mounted into the worker. Override this for rootless or non-standard
# Docker installations.
DOCKER_SOCKET=/var/run/docker.sock
TRAEFIK_SERVICE_URL=http://traefik:80
CONTROL_SUBNET=10.253.253.0/24
API_CONTROL_IP=10.253.253.2
TRAEFIK_CONTROL_IP=10.253.253.3
CLOUDFLARED_CONTROL_IP=10.253.253.4
WORKER_CONTROL_IP=10.253.253.5
TRUSTED_PROXY_IP=10.253.253.3
TRUSTED_CLOUDFLARED_IP=10.253.253.4

# Build and runtime limits.
MAX_UPLOAD_MB=500
DEPLOYMENT_MEMORY=1g
DEPLOYMENT_CPUS=1.0
HEALTHCHECK_TIMEOUT_SECONDS=60
BUILD_TIMEOUT_MINUTES=30
GIT_TIMEOUT_MINUTES=10
BUILD_CACHE_MAX_GB=8
# The dedicated BuildKit builder is bounded independently from deployed apps.
BUILD_MEMORY=2g
BUILD_MEMORY_SWAP=2g
BUILD_CPUS=1.0
BUILD_PIDS_LIMIT=1024
BUILD_MAX_PARALLELISM=2
# Source preparation/builds fail closed when less space is available.
BUILD_MIN_FREE_GB=5
# Must match the image built for the API/worker. Disposable health and preview
# helpers run this exact local image with no socket or host-volume access.
CONTROL_PLANE_IMAGE=shelter/control-plane:local
METRICS_INTERVAL_SECONDS=15
METRICS_RETENTION_HOURS=48
SESSION_TTL_HOURS=24
LOG_LEVEL=info

# Optional fallback: use these instead of connecting through Cloudflare OAuth.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Optional Cloudflare OAuth client. Create one private, self-managed OAuth client
# for this Shelter installation and register the exact, fixed callback URL.
CLOUDFLARE_OAUTH_CLIENT_ID=
# API only: keep the client secret in .env. The worker receives an explicit
# environment allowlist and must never inherit this value.
CLOUDFLARE_OAUTH_CLIENT_SECRET=
# Production example: https://panel.example.com/api/settings/cloudflare/oauth/callback
CLOUDFLARE_OAUTH_REDIRECT_URI=
# Optional HTTP(S) outbound proxy for OAuth token exchange and revocation only.
# Cloudflare API, deployment, and internal service requests remain direct.
CLOUDFLARE_OAUTH_PROXY_URL=
# Space-separated scope IDs. These required defaults correspond to Account Read,
# Zone Read, DNS Write, and Cloudflare Tunnel Write and can be checked against
# Cloudflare's authenticated /oauth/scopes endpoint.
CLOUDFLARE_OAUTH_SCOPES=account-settings.read zone.read dns.write argotunnel.write
